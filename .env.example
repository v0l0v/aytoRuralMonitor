# ============================================================================
# Archivo de configuración de variables de entorno (.env)
# Copiar a .env y completar con tus valores reales
# ============================================================================

# TELEGRAM BOT
# 1. Crear bot en @BotFather (https://t.me/botfather)
# 2. Obtener el TOKEN
# 3. Enviar un mensaje al bot y obtener el CHAT_ID
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# IDs de los destinatarios (puedes poner varios separados por comas)
TELEGRAM_RECIPIENTS=987654321

# WHATSAPP (usando Twilio)
# 1. Crear cuenta en https://www.twilio.com
# 2. Obtener ACCOUNT_SID y AUTH_TOKEN
# 3. Configurar número de WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+34600123456
# Números de los destinatarios (puedes poner varios separados por comas)
WHATSAPP_RECIPIENTS=whatsapp:+34700987654

# INFORMACIÓN DEL MUNICIPIO
# Personalizar según tu pueblo
MUNICIPALITY_NAME=Pueblo Rural Ejemplo
MUNICIPALITY_POPULATION=3500
MUNICIPALITY_COMMUNITY=Castilla-La Mancha
MUNICIPALITY_PROVINCE=Cuenca
MUNICIPALITY_POSTAL_CODE=16001
MUNICIPALITY_EMAIL=alcaldia@pueblorural.es
